#
# For Wasserman’s (MLE over θ₀ instead of all-reject rule)
#

library(MASS)
library(ggplot2)

## ---------------- Parameters ----------------
true_theta <- c(1,0,0,0,0)   # lies on the boundary in the first 3 dims
Sigma <- diag(5)
alpha <- 0.05
d0 <- 3
d1 <- 5
d  <- d1

## ------------- Adjusted alpha' (for pointwise test) -------------
f_alpha_prime <- function(alpha_prime) {
  q <- qchisq(1 - alpha_prime, df = d1)
  lhs <- 1 - alpha
  rhs <- 0.5 * (pchisq(q, df = d1 - d0) + pchisq(q, df = d1 - d0 + 1))
  lhs - rhs
}
alpha_new <- uniroot(f_alpha_prime, interval = c(1e-12, 1-1e-12))$root
cat("alpha' =", signif(alpha_new, 6), "\n")

## ------------- point generator (projection-based) -------------
# proj is the 3D projection of Y_bar (first 3 coords)
generate_test_points <- function(num_points, radius, proj) {
  raw_points <- proj + radius * cbind(0, matrix(rnorm(3*(num_points-1)), 3, num_points-1))
  points_3D <- apply(raw_points, 2, function(v) v / pmax(1, sqrt(sum(v^2))))
  rbind(points_3D, 0, 0)  # embed in R^5 by appending zeros
}

## ------------- pointwise test at a single theta0 -------------
test_theta_0_pointwise <- function(theta0, Y_bar, n, alpha_new) {
  Tstat <- sum((Y_bar - theta0)^2)
  crit  <- qchisq(1 - alpha_new, df = d) / n
  Tstat > crit
}

## ------------- Universal Inference (composite null via MLE) -------------
# Null set: ||theta_{1:3}|| <= 1, coords 4-5 = 0

# Restricted MLE in Θ0 given a mean vector m (project 1:3 onto unit ball if needed)
restricted_MLE_from_mean <- function(m) { ## modified
  m3 <- m[1:3]
  nrm <- sqrt(sum(m3^2))
  if (nrm <= 1) return(c(m3, 0, 0))          # already inside the ball
  c(m3 / nrm, 0, 0)                          # project 1:3 to boundary
}

# Split universal test (Wasserman): compare unrestricted vs restricted MLEs
universal_test_split_MLE <- function(Y, alpha) {
  n <- nrow(Y); d <- ncol(Y)
  n1 <- floor(n/2); idx <- sample(1:n, n1)
  D1 <- Y[idx, , drop = FALSE]
  D2 <- Y[-idx, , drop = FALSE]

  # unrestricted MLEs (means) on each split
  th2 <- colMeans(D2)

  # restricted MLEs in Θ0 from the held-out split means
  th0_D1 <- restricted_MLE_from_mean(colMeans(D1))

  # log-likelihood (up to constants) under Σ = I
  loglik <- function(mu, data) -0.5 * sum(rowSums((data - matrix(mu, nrow(data), d, byrow=TRUE))^2))

  # Held-out likelihood ratios (alt from the other fold)
  d1_alt <- loglik(th2, D1); d1_null <- loglik(th0_D1, D1)

  # Guard against overflow
  U1 <- exp(pmin(700, d1_alt - d1_null))

  as.integer(U1 > 1/alpha)
}

# Cross-fit universal test (Wasserman): compare unrestricted vs restricted MLEs
universal_test_crossfit_MLE <- function(Y, alpha) {
  n <- nrow(Y); d <- ncol(Y)
  n1 <- floor(n/2); idx <- sample(1:n, n1)
  D1 <- Y[idx, , drop = FALSE]
  D2 <- Y[-idx, , drop = FALSE]

  # unrestricted MLEs (means) on each split
  th1 <- colMeans(D1); th2 <- colMeans(D2)

  # restricted MLEs in Θ0 from the held-out split means
  th0_D1 <- restricted_MLE_from_mean(colMeans(D1))
  th0_D2 <- restricted_MLE_from_mean(colMeans(D2))

  # log-likelihood (up to constants) under Σ = I
  loglik <- function(mu, data) -0.5 * sum(rowSums((data - matrix(mu, nrow(data), d, byrow=TRUE))^2))

  # Held-out likelihood ratios (alt from the other fold)
  d1_alt <- loglik(th2, D1); d1_null <- loglik(th0_D1, D1)
  d2_alt <- loglik(th1, D2); d2_null <- loglik(th0_D2, D2)

  # Guard against overflow
  U1 <- exp(pmin(700, d1_alt - d1_null))
  U2 <- exp(pmin(700, d2_alt - d2_null))

  Wn <- (U1 + U2) / 2
  as.integer(Wn > 1/alpha)
}

## ------------- Simulation wrapper (comparison) -------------
simulate_compare_methods <- function(sample_sizes, num_points = 50, num_simulations = 1000,
                                     radius_rule = function(n) 3/sqrt(n)) {
  out <- data.frame(SampleSize = sample_sizes,
                    Pointwise = NA_real_, splitLRT = NA_real_, crossLRT = NA_real_,
                    Pointwise_me = NA_real_, splitLRT_me = NA_real_, crossLRT_me=NA_real_)
  for (i in seq_along(sample_sizes)) {
    n <- sample_sizes[i]
    rej_P  <- 0L
    rej_UIs <- 0L # split LRT
    rej_UIc <- 0L # cross-fit LRT

    for (sim in 1:num_simulations) {
      Y <- mvrnorm(n = n, mu = true_theta, Sigma = Sigma)
      Ybar <- colMeans(Y)

      ## ---- pointwise composite: ALL candidate points must berejected
      test_pts <- generate_test_points(num_points, radius_rule(n), Ybar[1:3])
      rejs <- sapply(1:ncol(test_pts), function(j) test_theta_0_pointwise(test_pts[, j], Ybar, n, alpha_new))
      if (all(rejs)) rej_P <- rej_P + 1L

      ## ---- Universal inference split LRT (composite via MLE; NO grid of points)
      rej_UIs <- rej_UIs + universal_test_split_MLE(Y, alpha)

      ## ---- Universal inference cross-fit LRT (composite via MLE; NO grid of points)
      rej_UIc <- rej_UIc + universal_test_crossfit_MLE(Y, alpha)
    }

    pP <- rej_P  / num_simulations
    pUs <- rej_UIs / num_simulations
    pUc <- rej_UIc / num_simulations

    seP <- if (pP > 0 && pP < 1) sqrt(pP*(1-pP)/num_simulations) else 0
    seUs <- if (pUs > 0 && pUs < 1) sqrt(pUs*(1-pUs)/num_simulations) else 0
    seUc <- if (pUc > 0 && pUc < 1) sqrt(pUc*(1-pUc)/num_simulations) else 0

    out$Pointwise[i]      <- pP
    out$splitLRT[i]   <- pUs
    out$crossLRT[i] <- pUc
    out$Pointwise_me[i]    <- 1.96*seP
    out$splitLRT_me[i]    <- 1.96*seUs
    out$crossLRT_me[i] <- 1.96*seUc
  }
  out
}

## ---------------- Run sims ----------------
sample_sizes    <- c(5, 10, 30, 100, 200, 1000)
num_points      <- 1
num_simulations <- 40000
set.seed(12345)

results <- simulate_compare_methods(sample_sizes, num_points, num_simulations)
print(results)

## Make SampleSize a factor so x–axis has equal spacing categories
results$SampleSize <- factor(results$SampleSize, levels = sample_sizes)

## ---------------- Reshape to long format: Pointwise vs Split vs Cross ----------------
results_long <- data.frame(
  SampleSize = rep(results$SampleSize, times = 3),
  Method = factor(
    rep(c("Pointwise", "Universal Split", "Universal Cross"),
        each = nrow(results)),
    levels = c("Pointwise", "Universal Split", "Universal Cross")
  ),
  Estimate = c(results$Pointwise,
               results$splitLRT,
               results$crossLRT),
  L = c(results$Pointwise - results$Pointwise_me,
        results$splitLRT - results$splitLRT_me,
        results$crossLRT - results$crossLRT_me),
  U = c(results$Pointwise + results$Pointwise_me,
        results$splitLRT + results$splitLRT_me,
        results$crossLRT + results$crossLRT_me)
)

## ---------------- Plot (three curves, legend outside) ----------------
grey_pal <- c("Pointwise"        = "black",
              "Universal Split"  = "red4",
              "Universal Cross"  = "red3")

p <- ggplot(results_long,
            aes(x = SampleSize, y = Estimate,
