  geom_line(linewidth = 1.2) +
  geom_point(size = 3) +
  # error bars around the estimate
  geom_errorbar(aes(ymin = pmax(0, L),
                    ymax = pmin(1, U)),
                width = 0.15) +
  geom_hline(yintercept = alpha, linetype = "dashed",
             color = "grey60", linewidth = 1) +
  scale_color_manual(values = grey_pal) +
  scale_shape_manual(values = c(19, 17, 15)) +
  labs(x = "Sample Size (n)", y = "Rejection Rate",
