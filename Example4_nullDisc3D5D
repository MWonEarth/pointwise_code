install.packages("reshape2")

library(MASS)
library(dplyr)
library(ggplot2)
library(reshape2)

# ---------- PARAMETERS ----------
Sigma <- diag(5)
alpha <- 0.05
d0 <- 3
d1 <- 5
d  <- d1

# adjusted alpha' for pointwise test
f_alpha_prime <- function(alpha_prime) {
  q <- qchisq(1 - alpha_prime, df = d1)
  lhs <- 1 - alpha
  rhs <- 0.5 * (pchisq(q, df = d1 - d0) + pchisq(q, df = d1 - d0 + 1))
  lhs - rhs
}
alpha_new <- uniroot(f_alpha_prime, interval = c(1e-12, 1-1e-12))$root
cat("Adjusted alpha' =", alpha_new, "\n")

# ---------- TEST POINT GENERATOR (projection-based) ----------
generate_test_points <- function(num_points, radius, proj) {
  raw_points <- proj + radius * cbind(0, matrix(rnorm(3*(num_points-1)), 3, num_points-1))
  points_3D <- apply(raw_points, 2, function(v) v / pmax(1, sqrt(sum(v^2))))
  rbind(points_3D, 0, 0)
}

# ---------- Pointwise Exact test ----------
test_theta_0_exact <- function(theta0, Y, alpha) {
  n <- nrow(Y); d <- ncol(Y)
  Ybar <- colMeans(Y)
  Tstat <- sum((Ybar - theta0)^2)
  crit  <- qchisq(1 - alpha, df = d) / n
  Tstat > crit
}
pointwise_test_composite <- function(Y_test, theta0_points, alpha) {
  rejections <- sapply(1:ncol(theta0_points),
                       function(j) test_theta_0_exact(theta0_points[,j], Y_test, alpha))
  as.integer(all(rejections))
}

# Restricted MLE in Θ0 given a mean vector m (project 1:3 onto unit ball if needed)
restricted_MLE_from_mean <- function(m) { ## modified
  m3 <- m[1:3]
  nrm <- sqrt(sum(m3^2))
  if (nrm <= 1) return(c(m3, 0, 0))          # already inside the ball
  c(m3 / nrm, 0, 0)                          # project 1:3 to boundary
}
universal_test_split_on_dataset <- function(Y, alpha) {
  n <- nrow(Y); d <- ncol(Y)
  n1 <- floor(n/2); idx <- sample(1:n, n1)
  D1 <- Y[idx, , drop=FALSE]; D0 <- Y[-idx, , drop=FALSE]
  theta_hat1 <- colMeans(D1)
  theta_hat0 <- restricted_MLE_from_mean(colMeans(D0))
  loglik <- function(mu, data) -0.5 * sum(rowSums((data - matrix(mu, nrow(data), d, byrow=TRUE))^2))
  U <- exp(loglik(theta_hat1, D0) - loglik(theta_hat0, D0))
  as.integer(U > 1/alpha)
}
universal_test_crossfit_on_dataset <- function(Y, alpha) {
  n <- nrow(Y); d <- ncol(Y)
  n1 <- floor(n/2); idx <- sample(1:n, n1)
  D1 <- Y[idx, , drop=FALSE]; D2 <- Y[-idx, , drop=FALSE]
  theta_hat1 <- colMeans(D1); theta_hat2 <- colMeans(D2)
  theta0_D1 <- restricted_MLE_from_mean(colMeans(D1))
  theta0_D2 <- restricted_MLE_from_mean(colMeans(D2))
  loglik <- function(mu, data) -0.5 * sum(rowSums((data - matrix(mu, nrow(data), d, byrow=TRUE))^2))
  U1 <- exp(loglik(theta_hat2, D1) - loglik(theta0_D1, D1))
  U2 <- exp(loglik(theta_hat1, D2) - loglik(theta0_D2, D2))
  Wn <- (U1 + U2) / 2
  as.integer(Wn > 1/alpha)
}

# ---------- Simulation wrapper ----------
simulate_power <- function(sample_sizes = c(5,10,30,100,200,1000),
                           effect_sizes = c(1.05, 1.2, 1.5),
                           num_points = 10,
                           num_simulations = 1000,
                           radius_rule = function(n) 3/sqrt(n),
                           seed = 123) {
  set.seed(seed)
  out_list <- list()
  for (mu_val in effect_sizes) {
    true_theta <- c(mu_val, rep(0, d-1))
    res_mat <- data.frame(SampleSize = sample_sizes,
                          Point = NA, UnivSplit = NA, UnivCross = NA)
    for (i in seq_along(sample_sizes)) {
      n_total <- sample_sizes[i]
      rejP <- rejS <- rejC <- 0
      for (sim in 1:num_simulations) {
        Y <- mvrnorm(n = n_total, mu = true_theta, Sigma = Sigma)
        Ybar <- colMeans(Y)
        theta0_points <- generate_test_points(num_points, radius_rule(n_total), Ybar[1:3])
        # pointwise
        rejP <- rejP + pointwise_test_composite(Y, theta0_points, alpha_new)
        # universal split & cross-fit
        rejS <- rejS + universal_test_split_on_dataset(Y, alpha)
        rejC <- rejC + universal_test_crossfit_on_dataset(Y, alpha)
      }
      res_mat$Point[i] <- rejP / num_simulations
      res_mat$UnivSplit[i] <- rejS / num_simulations
      res_mat$UnivCross[i] <- rejC / num_simulations
      cat(sprintf("mu=%.2f n=%d  Pointwise=%.3f  Split=%.3f  Cross=%.3f\n",
                  mu_val, n_total, res_mat$Point[i], res_mat$UnivSplit[i], res_mat$UnivCross[i]))
    }
    out_list[[as.character(mu_val)]] <- res_mat
  }
  out_list
}

# ---------- Run simulation ----------
sample_sizes <- c(5, 10, 30, 100, 200, 1000)
effect_sizes <- c(1.05, 1.2, 1.5)
num_simulations <- 10000
res_list <- simulate_power(sample_sizes, effect_sizes, num_points=1,
                           num_simulations=num_simulations, seed=2025)

