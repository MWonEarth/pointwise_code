# --- Libraries ---
library(ggplot2)
library(dplyr)

# --- Simulation function ---
simulate_test <- function(n = 20, sigma = 1, a = 0, b = 1,
                          alpha = 0.05, R = 5000, mu_values = seq(a, b, length.out = 101),
                          seed = 2025) {
  set.seed(seed)
  df <- n - 1
  t_crit_pointwise <- qt(1 - alpha, df)   # pointwise interval
  alpha_bc <- alpha / 2                   # Bonferroni split

  mu_list <- unique(mu_values)
  out <- lapply(mu_list, function(mu_true) {
    # simulate R samples
    X <- matrix(rnorm(n * R, mean = mu_true, sd = sigma), nrow = R, ncol = n)
    xbar <- rowMeans(X)
    s <- apply(X, 1, sd)

    # Pointwise rejection
    lower_pw <- a - t_crit_pointwise * s / sqrt(n)
    upper_pw <- b + t_crit_pointwise * s / sqrt(n)
    rej_pw <- (xbar < lower_pw) | (xbar > upper_pw)

    # Bonferroni rejection
    tstat_L <- (xbar - a) / (s / sqrt(n))
    p_left <- pt(tstat_L, df = df)
    rej_left <- p_left < alpha_bc

    tstat_R <- (xbar - b) / (s / sqrt(n))
    p_right <- 1 - pt(tstat_R, df = df)
    rej_right <- p_right < alpha_bc

    rej_bonf <- rej_left | rej_right

    data.frame(mu = mu_true,
               rej_pointwise = rej_pw,
               rej_bonf = rej_bonf)
  })

  df_out <- do.call(rbind, out)
  summary_df <- df_out %>%
    group_by(mu) %>%
    summarize(
      rejection_rate_pointwise = mean(rej_pointwise),
      rejection_rate_bonf = mean(rej_bonf),
      .groups = "drop"
    )

  # restrict to [a,b]
  interior <- summary_df %>% filter(mu >= a & mu <= b)

  # sizes
  size_pw <- mean(interior$rejection_rate_pointwise)
  size_bonf <- mean(interior$rejection_rate_bonf)
  max_pw <- max(interior$rejection_rate_pointwise)
  max_bonf <- max(interior$rejection_rate_bonf)

  return(list(
    summary = summary_df,
    size_pw = size_pw, size_bonf = size_bonf,
    max_pw = max_pw, max_bonf = max_bonf
  ))
}

# --- Run for multiple n ---
n_values <- c(5, 10, 20, 50, 200)
R <- 5000
a <- 0; b <- 1

results <- lapply(n_values, function(n) {
  sim <- simulate_test(n = n, a = a, b = b, R = R)
  data.frame(
    n = n,
    avg_size_pw = sim$size_pw,
    avg_size_bonf = sim$size_bonf,
    max_size_pw = sim$max_pw,
    max_size_bonf = sim$max_bonf
  )
})

results_df <- bind_rows(results)
print(results_df)

# --- Plot max rejection rate vs n ---
results_long <- results_df %>%
  select(n, max_size_pw, max_size_bonf) %>%
  tidyr::pivot_longer(cols = starts_with("max_size"),
                      names_to = "Method", values_to = "MaxRej") %>%
  mutate(Method = ifelse(Method == "max_size_pw", "Pointwise", "Bonferroni"))

ggplot(results_long, aes(x = n, y = MaxRej, color = Method)) +
  geom_line() + geom_point(size = 2) +
  geom_hline(yintercept = 0.05, linetype = "dotted") +
  labs(y = "Max rejection rate inside [a,b]", x = "Sample size n",
       title = "Empirical size vs n") +
  theme_minimal()

# --- Add SE and CI for error bars ---
results_long <- results_df %>%
  select(n, max_size_pw, max_size_bonf) %>%
  tidyr::pivot_longer(cols = starts_with("max_size"),
                      names_to = "Method", values_to = "MaxRej") %>%
  mutate(Method = ifelse(Method == "max_size_pw", "Pointwise", "Bonferroni"),
         n = factor(n)) %>%
  # compute SE (binomial approx) and 95% CI
  mutate(
    SE = sqrt(MaxRej * (1 - MaxRej) / R),
    CI_lower = pmax(MaxRej - 1.96 * SE, 0),
    CI_upper = pmin(MaxRej + 1.96 * SE, 1)
  )


# --- Plot with error bars (Fig6_1)---
ggplot(results_long, aes(x = n, y = MaxRej, color = Method, group = Method)) +
  geom_line(linewidth = 1.2, aes(group = Method)) +
  geom_point(size = 3) +
  geom_errorbar(aes(ymin = CI_lower, ymax = CI_upper), width = 0.15, linewidth = 0.8) +
  geom_hline(yintercept = 0.05, linetype = "dotted") +
  labs(y = "Max rejection rate inside [a,b]", x = "Sample size n") +
  scale_color_manual(values = c("Pointwise" = "black", "Bonferroni" = "red")) +
  #scale_y_continuous(
  #  limits = c(0, 0.06),
  #  breaks = c(0, 0.06, 0.05)  # force 0.05 to appear

  scale_y_continuous(
    limits = c(0, 0.06),
    breaks = seq(0, 0.06, 0.01)
  ) +
  theme_minimal(base_size = 16) +
  theme(
    plot.title = element_text(size = 20, face = "bold", hjust = 0.5),
    axis.title = element_text(size = 18),
    axis.text = element_text(size = 16),
    legend.title = element_text(size = 16),
    legend.text = element_text(size = 16)
  )

