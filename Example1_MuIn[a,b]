# Simulation comparing pointwise method vs Bonferroni for H0: mu in [a,b]
library(ggplot2)
library(dplyr)

simulate_test <- function(n = 20, sigma = 1, a = 0, b = 1,
                          alpha = 0.05, R = 10000, mu_values = seq(-1, 2, length.out = 50),
                          seed = 2025) {
  set.seed(seed)
  df <- n - 1
  t_crit_pointwise <- qt(1 - alpha, df)   # pointwise interval endpoints
  alpha_bc <- alpha / 2                    # Bonferroni per-side

  results <- expand.grid(mu = mu_values, rep = 1:R)
  results$rej_pointwise <- FALSE
  results$rej_bonf <- FALSE

  # iterate mu values (vectorized per mu for efficiency)
  mu_list <- unique(results$mu)
  out <- lapply(mu_list, function(mu_true) {
    # simulate R samples
    X <- matrix(rnorm(n * R, mean = mu_true, sd = sigma), nrow = R, ncol = n)
    xbar <- rowMeans(X)
    s <- apply(X, 1, sd)

    # Pointwise rejection: check if xbar outside [a - t_crit * s/sqrt(n), b + t_crit * s/sqrt(n)]
    lower_pw <- a - t_crit_pointwise * s / sqrt(n)
    upper_pw <- b + t_crit_pointwise * s / sqrt(n)
    rej_pw <- (xbar < lower_pw) | (xbar > upper_pw)

    # Bonferroni: left-sided test for H0: mu >= a  (reject if evidence mu < a)
    tstat_L <- (xbar - a) / (s / sqrt(n))
    p_left <- pt(tstat_L, df = df)            # small p_left => reject H0: mu >= a
    rej_left <- p_left < alpha_bc

    # Right-sided test for H0: mu <= b  (reject if evidence mu > b)
    tstat_R <- (xbar - b) / (s / sqrt(n))
    p_right <- 1 - pt(tstat_R, df = df)       # small p_right => reject H0: mu <= b
    rej_right <- p_right < alpha_bc

    rej_bonf <- rej_left | rej_right

    data.frame(mu = mu_true, rej_pointwise = rej_pw, rej_bonf = rej_bonf)
  })

  df_out <- do.call(rbind, out)
  summary_df <- df_out %>%
    group_by(mu) %>%
    summarize(
      rejection_rate_pointwise = mean(rej_pointwise),
      rejection_rate_bonf = mean(rej_bonf),
      n = n()
    ) %>% ungroup()

  return(list(raw = df_out, summary = summary_df))
}

