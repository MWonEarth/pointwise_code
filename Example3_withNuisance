library(ggplot2)

# Set parameters
n_sim <- 1000
sample_sizes <- c(5, 15, 30, 50, 100, 200)
sigma <- 1
theta_0 <- 1
phi_0 <- 2
alpha <- 0.05
alpha_new <- 1 - pchisq(qchisq(1 - alpha, df = 1), df = 2)
phi_values <- seq(1.9, 2.1, by = 0.01)
n_bootstrap <- 50

# Data generation
generate_data <- function(theta, phi, x, sigma) {
  epsilon <- rnorm(length(x), mean = 0, sd = sigma)
  y <- theta * phi * x + theta * phi^2 + epsilon
  return(y)
}

# Parameter estimation
estimate_parameters <- function(x, y) {
  model <- lm(y ~ I(x))
  beta_1 <- coef(model)[2]
  beta_0 <- coef(model)[1]
  phi_hat <- beta_0 / beta_1
  theta_hat <- beta_1 / phi_hat
  return(c(theta_hat, phi_hat))
}

# F-statistic calculation
calculate_f_statistic <- function(y, x, theta_0, phi_0, n) {
  y_null <- theta_0 * phi_0 * x + theta_0 * phi_0^2
  rss_null <- sum((y - y_null)^2)

  estimates <- estimate_parameters(x, y)
  theta_hat <- estimates[1]
  phi_hat <- estimates[2]
  y_alt <- theta_hat * phi_hat * x + theta_hat * phi_hat^2
  rss_alt <- sum((y - y_alt)^2)

  q <- 2
  p <- 2
  f_stat <- ((rss_null - rss_alt) / q) / (rss_alt / (n - p))

  return(f_stat)
}

# Bootstrap LRT for one sample
bootstrap_test <- function(x, y, theta_0, phi_values, alpha, B = 50) {
  n <- length(x)

  loglik_null_obs <- sapply(phi_values, function(phi) {
    mu_null <- theta_0 * phi * x + theta_0 * phi^2
    -sum((y - mu_null)^2)
  })
  max_loglik_null_obs <- max(loglik_null_obs)

  estimates <- estimate_parameters(x, y)
  mu_alt <- estimates[1] * estimates[2] * x + estimates[1] * estimates[2]^2
  loglik_alt_obs <- -sum((y - mu_alt)^2)

  lambda_obs <- loglik_null_obs - loglik_alt_obs
  lambda_obs_max <- max(lambda_obs)

  lambda_boot <- numeric(B)
  for (b in 1:B) {
    eps_boot <- sample(y - mu_alt, replace = TRUE)
    y_boot <- mu_alt + eps_boot

    loglik_null_boot <- sapply(phi_values, function(phi) {
      mu_null_b <- theta_0 * phi * x + theta_0 * phi^2
      -sum((y_boot - mu_null_b)^2)
    })
    max_loglik_null_boot <- max(loglik_null_boot)

    estimates_boot <- estimate_parameters(x, y_boot)
    mu_alt_b <- estimates_boot[1] * estimates_boot[2] * x + estimates_boot[1] * estimates_boot[2]^2
    loglik_alt_boot <- -sum((y_boot - mu_alt_b)^2)

    lambda_boot[b] <- max_loglik_null_boot - loglik_alt_boot
  }

  p_boot <- mean(lambda_boot >= lambda_obs_max)
  return(p_boot < alpha)
}

# Initialize results
results <- data.frame()

# Run simulation
for (n in sample_sizes) {
  f_rejections <- numeric(n_sim)
  boot_rejections <- numeric(n_sim)

  for (sim in 1:n_sim) {
    x <- rnorm(n)
    y <- generate_data(theta_0, phi_0, x, sigma)

    # F-test for each phi
    p_values_f <- numeric(length(phi_values))
    for (i in seq_along(phi_values)) {
      f_stat <- calculate_f_statistic(y, x, theta_0, phi_values[i], n)
      p_values_f[i] <- 1 - pf(f_stat, df1 = 2, df2 = n - 2)
    }
    f_rejections[sim] <- all(p_values_f < alpha_new)

    # Bootstrap test
    boot_rejections[sim] <- bootstrap_test(x, y, theta_0, phi_values, alpha, n_bootstrap)
  }

  # Confidence intervals
  calc_ci <- function(r) 1.96 * sqrt(r * (1 - r) / n_sim)

  f_rate <- mean(f_rejections)
  boot_rate <- mean(boot_rejections)

  results <- rbind(results, data.frame(
    SampleSize = n,
    Method = "F-statistic",
    RejectionRate = f_rate,
    LowerCI = f_rate - calc_ci(f_rate),
    UpperCI = f_rate + calc_ci(f_rate)
  ))

  results <- rbind(results, data.frame(
    SampleSize = n,
    Method = "Bootstrap",
    RejectionRate = boot_rate,
    LowerCI = boot_rate - calc_ci(boot_rate),
    UpperCI = boot_rate + calc_ci(boot_rate)
  ))
}

