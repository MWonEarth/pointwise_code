phi_0 <- 2  # true value for phi
alpha <- 0.05  # Significance level
alpha_new <- 1 - pchisq(qchisq(1 - alpha, df = 1), df = 2)  # Adjusted alpha for LRT

# Function to generate data based on the model
generate_data <- function(psi, phi, sigma) {
  x <- rnorm(n, mean = 0, sd = 1)  # Explanatory variable
  epsilon <- rnorm(length(x), mean = 0, sd = sigma)  # Random noise
  y <- psi * phi * x + psi * phi^2 + epsilon  # Model for y
  return(list(x=x, y=y))
}

# Function to estimate psi and phi using OLS
estimate_parameters <- function(x, y) {
  model <- lm(y ~ I(x))  # Linear model
  beta_1 <- coef(model)[2]  # Coefficient of x
  beta_0 <- coef(model)[1]  # Intercept
  phi_hat <- beta_0 / beta_1  # Estimate phi
  psi_hat <- beta_1 / phi_hat  # Estimate psi
  return(c(psi_hat, phi_hat))
}

# Calculate LRT statistic and F-statistic for each simulation
calculate_statistics <- function(y, x, psi_0, phi_proxy_variations, n) {
  stat_lrt <- numeric(length(phi_proxy_variations))
  stat_f <- numeric(length(phi_proxy_variations))

  # Alternative model (estimate parameters once)
  estimates <- estimate_parameters(x, y)
  psi_hat <- estimates[1]
  phi_hat <- estimates[2]
  y_alt <- psi_hat * phi_hat * x + psi_hat * phi_hat^2
  rss_alt <- sum((y - y_alt)^2)  # Residual sum of squares for alternative model

  phi_values <- phi_hat + phi_proxy_variations

  for (i in seq_along(phi_values)) {
    # Null model
    phi_0 <- phi_values[i] # proxy test value for phi
    y_null <- psi_0 * phi_0 * x + psi_0 * phi_0^2
    rss_null <- sum((y - y_null)^2)  # Residual sum of squares for null model

    # LRT statistic
    stat_lrt[i] <- n * log(rss_null / rss_alt)

    # F-statistic
    q <- 2  # Difference in parameters
    p <- 2  # Parameters in the alternative model
    stat_f[i] <- ((rss_null - rss_alt) / q) / (rss_alt / (n - p))
  }

  return(list(lrt_stat = min(stat_lrt), f_stat = min(stat_f)))
}

set.seed(123)

psi_alt <- 1.5  # Alternative value for psi

# Set the number of simulations
n_sim <- 1000

n <- 5 # sample size

# Store the rejection results for each simulation for both tests
lrt_rejections <- numeric(n_sim)
f_stat_rejections <- numeric(n_sim)

# Simulate the process under the alternative hypothesis
for (sim in 1:n_sim) {
  # Generate data under the alternative hypothesis
  data_output <- generate_data(psi_alt, phi_0, sigma)
  y <- data_output$y
  x <- data_output$x

  phi_proxy_variations <- 1/sqrt(n) * seq(-5, 5, length.out=50)

  # Test if null hypothesis (psi = psi_0) is rejected using LRT and F-statistic
  stats <- calculate_statistics(y, x, psi_0, phi_proxy_variations, n)
  lrt_stat <- stats$lrt_stat
  f_stat <- stats$f_stat

  # Rejection based on LRT
  lrt_rejections[sim] <- (lrt_stat > qchisq(1-alpha, df=1))

  # Rejection based on F-statistic
  f_stat_rejections[sim] <- (f_stat > qf(1-alpha_new, df1=2, df2=n-2))
}

# Calculate the power of the tests
