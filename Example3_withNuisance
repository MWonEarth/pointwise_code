#################################################################################
############## compare F-interval with chi-square interval (test around phi MLE)
#################################################################################

# Define parameters
# Model: Y = psi * phi * x + psi * phi^2 + epsilon
# psi: parameter of interest
# phi: nuisance parameter
n_values <- c(5, 15, 30, 50, 100, 200)  # Different sample sizes
sigma <- 1  # Standard deviation of noise
psi_0 <- 1  # Null value for psi
phi_0 <- 2  # Null value for phi
alpha <- 0.05  # Significance level
alpha_new <- 1 - pchisq(qchisq(1 - alpha, df = 1), df = 2)  # Adjusted alpha for LRT
# In this modified version of Notebook, the test phi values are chosen in the range of MLE +- 3/sqrt(n)
# (instead of from a fixed interval (1.9, 2.1))

# Function to generate data based on the model
generate_data <- function(psi, phi, sigma) {
  x <- rnorm(n, mean = 0, sd = 1)
  epsilon <- rnorm(length(x), mean = 0, sd = sigma)
  y <- psi * phi * x + psi * phi^2 + epsilon
  # Return a list containing x, y, and epsilon
  return(list(x = x, y = y, epsilon = epsilon))
}

# Function to estimate psi and phi using OLS
estimate_parameters <- function(x, y) {
  model <- lm(y ~ I(x))  # Linear model
  beta_1 <- coef(model)[2]  # Coefficient of x
  beta_0 <- coef(model)[1]  # Intercept
  phi_hat <- beta_0 / beta_1  # Estimate phi
  psi_hat <- beta_1 / phi_hat  # Estimate psi
  return(c(psi_hat, phi_hat))
}

# Function to calculate the likelihood
calculate_rss <- function(y, x, psi, phi) {
  y_pred <- psi * phi * x + psi * phi^2  # Model predictions
  rss <- sum((y - y_pred)^2)  # Residual sum of squares (RSS)
  return(rss)
}

# Function to merge intervals
merge_intervals <- function(intervals) {
  # Remove NA intervals
  valid_intervals <- intervals[!sapply(intervals, function(x) all(is.na(x)))]
  # Return NA if no valid intervals remain
  if (length(valid_intervals) == 0) {
    cat("No valid intervals remaining.\n")
    return(NA)
  }

  # Sort intervals by their lower bound
  # Handle cases where valid_intervals may be empty or contain only NA
  if (length(valid_intervals) > 0 && !all(is.na(valid_intervals))) {
    valid_intervals <- valid_intervals[order(sapply(valid_intervals, `[`, 1))]
  }

  # Initialize merged intervals list
  # Handle case where valid_intervals may be empty
  if (length(valid_intervals) > 0) {
    merged <- list(valid_intervals[[1]])
  } else {
    return(NA) # Return NA if no valid intervals to merge
  }

  # Merge overlapping or adjacent intervals
  # Iterate only if there are intervals to merge
  if (length(valid_intervals) > 1) {
    for (i in 2:length(valid_intervals)) {
      last_interval <- merged[[length(merged)]]
      current_interval <- valid_intervals[[i]]

      # Check for overlap or adjacency
      if (last_interval[2] >= current_interval[1]) {
        # Merge intervals
        merged[[length(merged)]] <- c(last_interval[1], max(last_interval[2], current_interval[2]))
      } else {
        # Append non-overlapping interval
        merged <- append(merged, list(current_interval))
      }
    }
  }
  return(merged)
}

# Function to check if psi_0 is in union of intervals
psi_in_union <- function(intervals, psi_0) {
  # Check if intervals is NULL or NA
  if (is.null(intervals) || all(is.na(intervals))) {
    return(0)  # Return 0 if intervals is empty or NA
  }

  # If intervals is not empty, proceed as before
  for (i in 1:length(intervals)) { # Change from nrow to length to handle list
    interval <- intervals[[i]] # Extract the interval from the list
    if (psi_0 >= interval[1] && psi_0 <= interval[2]) {
      return(1)
    }
  }
  return(0)
}

# Set the number of simulations
n_simulations <- 10000

set.seed(123)  # For reproducibility

# Store results
results <- data.frame(n = integer(), method = character(), proportion = numeric())

# Loop through each sample size
for (n in n_values) {

  f_proportions <- numeric(n_simulations)
  chi_proportions <- numeric(n_simulations)

  for (sim in 1:n_simulations) {
    # Generate new data
    data_output <- generate_data(psi_0, phi_0, sigma)
    y_values <- data_output$y
    x_values <- data_output$x

    # Estimate MLEs for psi and phi
    params_hat <- estimate_parameters(x_values, y_values)
    psi_hat <- params_hat[1]
    phi_hat <- params_hat[2]

    # Calculate RSS under MLEs
    rss_mle <- calculate_rss(y_values, x_values, psi_hat, phi_hat)

    # F-based intervals
    critical_value_f <- qf(1 - alpha_new, df1 = 2, df2 = n - 2)
    f_intervals_sim <- list()

    for (phi in phi_hat + 1/sqrt(n)*seq(-5,5,length.out=50)) {
      A <- phi^2 * sum((x_values + phi)^2)
      B <- -2 * phi * sum((x_values + phi) * y_values)
      C <- sum((y_values)^2) - ((2 * critical_value_f) / (n - 2) + 1) * rss_mle
      discriminant <- B^2 - 4 * A * C
      if (discriminant > 0) {
        psi_0_1 <- (-B - sqrt(discriminant)) / (2 * A)
        psi_0_2 <- (-B + sqrt(discriminant)) / (2 * A)
        f_intervals_sim[[as.character(phi)]] <- c(psi_0_1, psi_0_2)
      }
    }
    f_union_intervals <- merge_intervals(f_intervals_sim)
    f_proportions[sim] <- psi_in_union(f_union_intervals, psi_0)

    # Chi-square intervals
    critical_value_chi <- qchisq(1 - alpha, df = 1) ## changed
    chi_intervals_sim <- list()

    for (phi in phi_hat + 1/sqrt(n)*seq(-5,5,length.out=50)) {
      A <- phi^2 * sum((x_values + phi)^2)
      B <- -2 * phi * sum((x_values + phi) * y_values)
      C <- sum((y_values)^2) - exp(critical_value_chi / n) * rss_mle
      discriminant <- B^2 - 4 * A * C
      if (discriminant > 0) {
        psi_0_1 <- (-B - sqrt(discriminant)) / (2 * A)
        psi_0_2 <- (-B + sqrt(discriminant)) / (2 * A)
        chi_intervals_sim[[as.character(phi)]] <- c(psi_0_1, psi_0_2)
      }
    }
    chi_union_intervals <- merge_intervals(chi_intervals_sim)
    chi_proportions[sim] <- psi_in_union(chi_union_intervals, psi_0)
  }

  # Store results
  results <- rbind(
    results,
    data.frame(n = n, method = "Finite-sample F test", proportion = mean(f_proportions)),
    data.frame(n = n, method = "Likelihood ratio test", proportion = mean(chi_proportions))
  )
}

