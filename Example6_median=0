make_gamma_dictionary <- function(shapes = c(2,3,5), rate = 1) {
  dict <- list()
  for (sh in shapes) {
    dict[[paste0("Gamma(sh=", sh, ",med0)")]] <- local({
      sh0 <- sh
      rate0 <- rate
      med0 <- qgamma(0.5, shape = sh0, rate = rate0)
      list(
        r = function(n) rgamma(n, shape = sh0, rate = rate0) - med0,
        p = function(x) pgamma(x + med0, shape = sh0, rate = rate0)
      )
    })
  }
  dict
}

