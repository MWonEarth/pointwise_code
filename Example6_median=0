## ============================================================
## Pointwise rejection for H0: median = 0 using KS over a null dictionary
## Two-sided alternative
## ============================================================

## ---------- 1) Null dictionary: fully specified median-0 distributions ----------
# We need for each F_k:
#  - r(n): sampler
#  - p(x): CDF function for ks.test

make_null_dictionary <- function() {
  dict <- list()

  ## 1) Normal(0,1)
  dict[["N(0,1)"]] <- list(
    r = function(n) rnorm(n, 0, 1),
    p = function(x) pnorm(x, 0, 1)
  )

  ## 2) Laplace(0,1)
  rlaplace01 <- function(n) {
    u <- runif(n)
    ifelse(u < 0.5, log(2*u), -log(2*(1-u)))
  }
  plaplace01 <- function(x) {
    ifelse(x < 0, 0.5*exp(x), 1 - 0.5*exp(-x))
  }
  dict[["Laplace(0,1)"]] <- list(r = rlaplace01, p = plaplace01)

  ## 3) t distributions (df fixed) — SAFE CAPTURE USING local()
  for (nu in c(3, 5, 10)) {
    dict[[paste0("t(df=", nu, ")")]] <- local({
      nu0 <- nu
      list(
        r = function(n) rt(n, df = nu0),
        p = function(x) pt(x, df = nu0)
      )
    })
  }

  ## 4) Contaminated normal mixtures: (1-eps)N(0,1) + eps N(0,9)
  mix_cdf <- function(x, eps, sd2) {
    (1 - eps) * pnorm(x, 0, 1) + eps * pnorm(x, 0, sd2)
  }
  mix_r <- function(n, eps, sd2) {
    z <- rbinom(n, 1, eps)
    rnorm(n, 0, ifelse(z == 1, sd2, 1))
  }

  for (eps in c(0.05, 0.10)) {
    dict[[paste0("ContamN(eps=", eps, ",sd=3)")]] <- local({
      eps0 <- eps
      list(
        r = function(n) mix_r(n, eps = eps0, sd2 = 3),
        p = function(x) mix_cdf(x, eps = eps0, sd2 = 3)
      )
    })
  }

  dict
}

null_dict <- make_null_dictionary()
names(null_dict)



## ---------- 2) KS p-values against each candidate ----------
ks_pvals_against_dict <- function(x, dict) {
  sapply(dict, function(Fk) {
    # one-sample KS: compare empirical CDF to specified Fk CDF
    ks.test(x, Fk$p)$p.value
  })
}

## ---------- 3) Pointwise rejection rule ----------
# Reject if max p-value is small (all candidates look implausible)
pointwise_reject <- function(x, dict, alpha_new) {
  pvals <- ks_pvals_against_dict(x, dict)
  as.integer(max(pvals) <= alpha_new)
}

## ---------- 4) Calibrate alpha_new by simulation (worst-case over null candidates) ----------
# We simulate under each F_k, compute M = max_j p_j, then find a threshold
# alpha_new such that P(M <= alpha_new) <= alpha for each k.
calibrate_alpha_new <- function(n, dict, alpha=0.05, nsim=2000, seed=1) {
  set.seed(seed)
  M_by_k <- matrix(NA_real_, nrow=nsim, ncol=length(dict))
  colnames(M_by_k) <- names(dict)

  for (k in seq_along(dict)) {
    Fk <- dict[[k]]
    for (b in 1:nsim) {
      x <- Fk$r(n)
      pvals <- ks_pvals_against_dict(x, dict)
      M_by_k[b, k] <- max(pvals)
    }
  }

  # For each generating null k, find alpha-quantile of M.
  # To be conservative (level alpha for all k), take the minimum across k.
  q_by_k <- apply(M_by_k, 2, quantile, probs=alpha, type=8, names=FALSE)
  alpha_new <- min(q_by_k)

  list(alpha_new=alpha_new, q_by_k=q_by_k, M_by_k=M_by_k)
}

## ---------- 5) Competing methods: sign test and Wilcoxon signed-rank ----------
sign_test_pval <- function(x) {
  # drop zeros for continuity robustness
  x2 <- x[x != 0]
  n2 <- length(x2)
  S <- sum(x2 > 0)
  # exact two-sided binomial p-value
  p_lo <- pbinom(S, n2, 0.5)
  p_hi <- 1 - pbinom(S - 1, n2, 0.5)
  2 * min(p_lo, p_hi)
}

wilcoxon_pval <- function(x) {
  wilcox.test(x, mu=0, alternative="two.sided", exact=FALSE)$p.value
}

## ---------- 6) Run size/power simulation ----------
run_power_study_twosided_avg <- function(
  sample_sizes = c(10, 20, 40, 80),
  deltas_abs = c(0, 0.1, 0.2, 0.3, 0.4),
  base_null_name = "N(0,1)",
  alpha = 0.05,
  nsim_cal = 2000,
  nsim_pow = 2000,
  seed = 1
) {
  set.seed(seed)

  out <- list()
  idx <- 1

  for (n in sample_sizes) {

    # calibrate alpha_new
    cal <- calibrate_alpha_new(n=n, dict=null_dict, alpha=alpha,
                               nsim=nsim_cal, seed=seed + 1000 + n)
    alpha_new <- cal$alpha_new

    for (d in deltas_abs) {

      deltas_use <- if (d == 0) c(0) else c(-d, d)

      rej_mat <- matrix(0, nrow=length(deltas_use), ncol=3)
      colnames(rej_mat) <- c("Pointwise-KS", "Sign", "Wilcoxon")

      for (s in seq_along(deltas_use)) {
        delta <- deltas_use[s]

        rej_point <- 0
        rej_sign  <- 0
        rej_wilc  <- 0

        for (b in 1:nsim_pow) {
          z <- null_dict[[base_null_name]]$r(n)
          x <- z + delta

          rej_point <- rej_point + as.integer(max(ks_pvals_against_dict(x, null_dict)) <= alpha_new)
          rej_sign  <- rej_sign  + as.integer(sign_test_pval(x) <= alpha)
          rej_wilc  <- rej_wilc  + as.integer(wilcoxon_pval(x) <= alpha)
        }

        rej_mat[s, ] <- c(rej_point, rej_sign, rej_wilc) / nsim_pow
      }

      avg_rates <- colMeans(rej_mat)

      # Monte Carlo SE for averaged rejection rate
      se_rates <- sqrt(avg_rates * (1 - avg_rates) / nsim_pow)

      out[[idx]] <- data.frame(
        n = n,
        delta_abs = d,
        alpha_new = alpha_new,
        method = names(avg_rates),
        reject_rate = as.numeric(avg_rates),
        se = as.numeric(se_rates),
        nsim = nsim_pow
      )

      idx <- idx + 1
    }
  }

  do.call(rbind, out)
}



