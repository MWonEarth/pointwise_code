## ============================================================
## FAST sample-splitting pointwise KS:
## - Split data into A (select dictionary) and B (test)
## - Precompute alpha_new for each (dictionary, nB) once
## - Two-sided alternative summarized by averaging ±delta
## ============================================================

## ---------- 0) Already have these from earlier ----------
## ks_pvals_against_dict(), calibrate_alpha_new(), sign_test_pval(), wilcoxon_pval()
## plus the dictionary builders make_symmetric_dictionary(), make_gamma_dictionary()

sym_dict   <- make_symmetric_dictionary()
gamma_dict <- make_gamma_dictionary(shapes = c(2,3,5))

## ---------- 1) Dictionary selection on split A ----------
dict_fit_score <- function(x, dict) {
  min(sapply(dict, function(Fk) as.numeric(ks.test(x, Fk$p)$statistic)))
}

choose_dictionary <- function(xA, sym_dict, gamma_dict) {
  score_sym   <- dict_fit_score(xA, sym_dict)
  score_gamma <- dict_fit_score(xA, gamma_dict)

  if (score_gamma < score_sym) {
    list(name="Gamma", dict=gamma_dict, score_sym=score_sym, score_gamma=score_gamma)
  } else {
    list(name="Symmetric", dict=sym_dict, score_sym=score_sym, score_gamma=score_gamma)
  }
}



## ---------- 2) Precompute alpha_new for each nB and dictionary ----------
precompute_alpha_news <- function(
  sample_sizes,
  split_frac = 0.3,
  sym_dict,
  gamma_dict,
  alpha = 0.05,
  nsim_cal = 5000,
  seed = 1
) {
  set.seed(seed)

  alpha_sym   <- setNames(numeric(length(sample_sizes)), sample_sizes)
  alpha_gamma <- setNames(numeric(length(sample_sizes)), sample_sizes)

  for (n in sample_sizes) {
    nB <- n - floor(n*split_frac)

    cal_sym <- calibrate_alpha_new(
      n = nB, dict = sym_dict, alpha = alpha, nsim = nsim_cal,
      seed = seed + 1000 + n
    )
    cal_gam <- calibrate_alpha_new(
      n = nB, dict = gamma_dict, alpha = alpha, nsim = nsim_cal,
      seed = seed + 2000 + n
    )

    alpha_sym[as.character(n)]   <- cal_sym$alpha_new
    alpha_gamma[as.character(n)] <- cal_gam$alpha_new
  }

  list(alpha_sym = alpha_sym, alpha_gamma = alpha_gamma)
}

## ---------- 3) One replicate: split, select dictionary, test on B ----------
split_pointwise_one <- function(
  x,
  sym_dict,
  gamma_dict,
  alpha_new_sym,
  alpha_new_gamma,
  split_frac = 0.3,
  seed = NULL
) {
  if (!is.null(seed)) set.seed(seed)

  n <- length(x)
  idx <- sample.int(n)
  nA <- floor(n * split_frac)

  A <- x[idx[1:nA]]
  B <- x[idx[(nA+1):n]]

  choice <- choose_dictionary(A, sym_dict, gamma_dict)

  if (choice$name == "Gamma") {
    alpha_new <- alpha_new_gamma
    dict_use  <- gamma_dict
  } else {
    alpha_new <- alpha_new_sym
    dict_use  <- sym_dict
  }

  pvals_B <- ks_pvals_against_dict(B, dict_use)
  reject  <- as.integer(max(pvals_B) <= alpha_new)

  list(reject = reject, chosen = choice$name)
}

## ---------- 4) Simulation study (two-sided avg), compares 3 methods ----------
run_split_power_study_twosided_avg_fast <- function(
  sample_sizes = c(10, 20, 40),
  deltas_abs   = c(0, 0.1, 0.2, 0.3),
  base_r       = function(n) rnorm(n),  # generator for Z, then X = Z + delta
  sym_dict,
  gamma_dict,
  alpha_new_sym_vec,
  alpha_new_gamma_vec,
  alpha = 0.05,
  nsim = 5000,
  split_frac = 0.3,
  seed = 1
) {
  set.seed(seed)

  out <- list()
  idx <- 1

  for (n in sample_sizes) {
    nB <- n - floor(n * split_frac)
    alpha_new_sym   <- as.numeric(alpha_new_sym_vec[as.character(n)])
    alpha_new_gamma <- as.numeric(alpha_new_gamma_vec[as.character(n)])

    for (d in deltas_abs) {
      deltas_use <- if (d == 0) c(0) else c(-d, d)

      # store for +d and -d then average
      rej_point_side <- numeric(length(deltas_use))
      rej_sign_side  <- numeric(length(deltas_use))
      rej_wilc_side  <- numeric(length(deltas_use))
      gamma_chosen_side <- numeric(length(deltas_use))

      for (s in seq_along(deltas_use)) {
        delta <- deltas_use[s]

        rej_point <- integer(nsim)
        rej_sign  <- integer(nsim)
        rej_wilc  <- integer(nsim)
        ch_gamma  <- integer(nsim)

        for (b in 1:nsim) {
          z <- base_r(n)
          x <- z + delta

          # pointwise split
          ans <- split_pointwise_one(
            x = x,
            sym_dict = sym_dict,
            gamma_dict = gamma_dict,
            alpha_new_sym = alpha_new_sym,
            alpha_new_gamma = alpha_new_gamma,
            split_frac = split_frac,
            seed = seed + 100000*n + 1000*s + b
          )

          rej_point[b] <- ans$reject
          ch_gamma[b]  <- as.integer(ans$chosen == "Gamma")

          # classical tests on full sample (not split; these are baselines)
          rej_sign[b] <- as.integer(sign_test_pval(x) <= alpha)
          rej_wilc[b] <- as.integer(wilcoxon_pval(x) <= alpha)
        }

        rej_point_side[s] <- mean(rej_point)
        rej_sign_side[s]  <- mean(rej_sign)
        rej_wilc_side[s]  <- mean(rej_wilc)
        gamma_chosen_side[s] <- mean(ch_gamma)
      }

      # two-sided average over ±d
      point_avg <- mean(rej_point_side)
      sign_avg  <- mean(rej_sign_side)
      wilc_avg  <- mean(rej_wilc_side)

      # MC SEs (standard approx)
      point_se <- sqrt(point_avg * (1 - point_avg) / nsim)
      sign_se  <- sqrt(sign_avg  * (1 - sign_avg)  / nsim)
      wilc_se  <- sqrt(wilc_avg  * (1 - wilc_avg)  / nsim)

      gamma_chosen_avg <- mean(gamma_chosen_side)

      out[[idx]] <- data.frame(
        n = n, nB = nB, delta_abs = d,
        method = c("Pointwise-KS (split)", "Sign", "Wilcoxon"),
        reject_rate = c(point_avg, sign_avg, wilc_avg),
        se = c(point_se, sign_se, wilc_se),
        nsim = nsim,
        alpha_new_sym = alpha_new_sym,
        alpha_new_gamma = alpha_new_gamma,
        gamma_chosen_rate = gamma_chosen_avg

      )
      idx <- idx + 1
    }
  }

  do.call(rbind, out)
}

