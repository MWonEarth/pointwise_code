# Alternatives (mean != median typically)

r_alt_exp_contam <- function(n, delta, shift = 2) {
  p <- pmin(pmax(delta, 0), 0.50)  # now p(0)=0
  z <- rnorm(n)
  e <- rexp(n) - 1 + shift
  mix <- rbinom(n, 1, p)
  ifelse(mix == 1, e, z)
}

r_alt_spiky_weight <- function(n, delta, sd = 1) {
  # map delta in [0,0.4] to w in [0.5,0.65]
  w <- 0.5 + (0.15/0.4) * delta   # = 0.5 + 0.375*delta
  s <- rbinom(n, 1, w)
  ifelse(s == 1,  2 + rnorm(n, sd = sd),
                -2 + rnorm(n, sd = sd))
}

r_alt_g_and_h <- function(n, delta, h = 0.0) {
  z <- rnorm(n)
  g <- delta
  if (abs(g) < 1e-12) {
    x <- z * exp(0.5 * h * z^2)
  } else {
    x <- (exp(g * z) - 1) / g * exp(0.5 * h * z^2)
  }
  x
}

