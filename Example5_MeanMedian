run_power_compare_fast2 <- function(n = 40,
                                    deltas = seq(-0.4, 0.4, by = 0.1),
                                    alpha = 0.05,
                                    nsim = 1000,
                                    B = 500,
                                    K = 31,
                                    delta_grid_halfwidth = function(x) 3 * sd(x) / sqrt(length(x)),
                                    use_m_out_of_n = TRUE,
                                    m_power = 0.7,
                                    seed = 2) {

    alt_list <- list(
    "g-and-h skew"         = function(nn, d) r_alt_g_and_h(nn, delta = d, h = 0),
    "exp contamination"    = function(nn, d) r_alt_exp_contam(nn, delta = d),   # fixed p(0)=0
    "Asymmetric Gaussian mixture" = function(nn, d) r_alt_spiky_weight(nn, delta = d)  # use sd=1
  )


  set.seed(seed)
  out <- list(); idx <- 1

  for (alt_name in names(alt_list)) {
    rAlt <- alt_list[[alt_name]]

    for (d in deltas) {
      rej_pw <- logical(nsim)
      rej_h  <- logical(nsim)

      for (i in seq_len(nsim)) {
        x <- rAlt(n, d)

        bt <- boot_th_and_h(x, B = B,
                            use_m_out_of_n = use_m_out_of_n,
                            m_power = m_power)

        # ---- pointwise over diagonal t-grid ----
        th_hat <- bt$th_hat
        Sinv <- solve(bt$Sigma_hat + diag(1e-10, 2))
        a_new <- alpha_new(alpha, 1, 2)
        q2 <- qchisq(1 - a_new, df = 2)

        delt_half <- if (is.function(delta_grid_halfwidth)) delta_grid_halfwidth(x) else as.numeric(delta_grid_halfwidth)

        #delt_half <- if (is.function(delta_grid_halfwidth)) delta_grid_halfwidth(x) else delta_grid_halfwidth
        tgrid <- seq(th_hat[1] - delt_half, th_hat[1] + delt_half, length.out = K)

        D <- cbind(th_hat[1] - tgrid, th_hat[2] - tgrid)
        stats <- rowSums((D %*% Sinv) * D)
        rej_pw[i] <- all(stats > q2)

        # ---- general test of h=0 from same bootstrap ----
        rej_h[i] <- test_general_h_from_boot(bt$h_star, alpha = alpha)$reject
      }

      p_pw <- mean(rej_pw); p_h <- mean(rej_h)

      out[[idx]] <- data.frame(
        Study="Power", n=n, Alt=alt_name, delta=d,
        Method = if (use_m_out_of_n) "Pointwise over t-grid (m-out-of-n)" else "Pointwise over t-grid",
        RejectRate=p_pw,
        SE=sqrt(p_pw*(1-p_pw)/nsim),
        nsim=nsim, B=B, K=K
      ); idx <- idx + 1

      out[[idx]] <- data.frame(
        Study="Power", n=n, Alt=alt_name, delta=d,
        Method="Benchmark test of h=0",
        RejectRate=p_h,
        SE=sqrt(p_h*(1-p_h)/nsim),
        nsim=nsim, B=B, K=K
      ); idx <- idx + 1
    }
  }

  do.call(rbind, out)
}
