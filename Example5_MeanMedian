library(ggplot2)

plot_size_compare <- function(df, alpha = 0.05) {
  ggplot(df, aes(x=factor(n), y=RejectRate, color=Method, group=Method)) +
    geom_line(linewidth=1) +
    geom_point(size=2) +
    geom_errorbar(aes(ymin=pmax(0, RejectRate-1.96*SE),
                      ymax=pmin(1, RejectRate+1.96*SE)),
                  width=0.2) +
    facet_wrap(~Dist, nrow=1) +
    geom_hline(yintercept=alpha, linetype="dashed") +
    labs(x="Sample size n", y="Rejection rate") +
    theme_minimal(base_size=14)
}

size_df_m <- run_size_compare_fast(sample_sizes=c(20,40,80,160),
                              nsim=3000, B=1000, K=31,
                              use_m_out_of_n = TRUE,
                              seed=123)
options(repr.plot.width = 14, repr.plot.height = 4)
