################ testing null: mean = median ###############


alpha_new <- function(alpha, d0 = 1, d1 = 2) {
  cval <- qchisq(1 - alpha, df = d1 - d0)
  1 - pchisq(cval, df = d1)
}
#################
boot_th_and_h <- function(x, B = 1000,
                          use_m_out_of_n = FALSE,
                          m_power = 0.7) {
  n <- length(x)

  if (!use_m_out_of_n) {
    m <- n
  } else {
    m <- max(10L, floor(n^m_power))
  }

  idx <- matrix(sample.int(n, size = m * B, replace = TRUE),
                nrow = m, ncol = B)
  x_star <- matrix(x[idx], nrow = m, ncol = B)

  means <- colMeans(x_star)
  meds  <- apply(x_star, 2, median)

  th_star <- cbind(means, meds)

  Sigma_hat <- cov(th_star)
  if (use_m_out_of_n) {
    Sigma_hat <- Sigma_hat * (m / n)
  }

  # ---- h bootstrap, scaled to n-level when m-out-of-n ----
  h_hat  <- mean(x) - median(x)
  h_star <- means - meds

  if (use_m_out_of_n) {
    h_star <- h_hat + sqrt(m / n) * (h_star - h_hat)
  }

  list(
    th_hat = c(mean(x), median(x)),
    Sigma_hat = Sigma_hat,
    h_hat = h_hat,
    h_star = h_star,
    m = m, n = n
  )
}


#################
test_pointwise_diag_fast <- function(x, alpha = 0.05,
                                     delta = function(x) 2 * sd(x) / sqrt(length(x)),
                                     K = 31,
                                     B = 1000,
                                     use_m_out_of_n = FALSE,
                                     m_power = 0.7,
                                     ridge = 1e-10) {

  bt <- boot_th_and_h(x, B = B,
                      use_m_out_of_n = use_m_out_of_n,
                      m_power = m_power)

  th_hat <- bt$th_hat
  Sigma_hat <- bt$Sigma_hat

  Sinv <- solve(Sigma_hat + diag(ridge, 2))

  a_new <- alpha_new(alpha, d0 = 1, d1 = 2)
  q2 <- qchisq(1 - a_new, df = 2)

  delt <- if (is.function(delta)) delta(x) else delta
  xbar <- th_hat[1]
  tgrid <- seq(xbar - delt, xbar + delt, length.out = K)

  # D is K x 2 matrix of (mean - t, median - t)
  D <- cbind(th_hat[1] - tgrid, th_hat[2] - tgrid)

  # quadratic form for each row: d' Sinv d
  stats <- rowSums((D %*% Sinv) * D)

  list(
    reject = all(stats > q2),
    alpha_new = a_new,
    q = q2,
    delta_used = delt,
    use_m_out_of_n = use_m_out_of_n
  )
}
