  ifelse(mix == 1, big, z)
}

r_null_laplace <- function(n, b = 1) {
  u <- runif(n) - 0.5
  -b * sign(u) * log(1 - 2 * abs(u))
}

#########################
## add the asymetric Gaussian mixture with delta=0 to the list of nulls
##########################

r_null_asym_gaussian_mix0 <- function(n, sd = 1) {
  # delta = 0 case of the "Asymmetric Gaussian mixture" from the power study
  # When delta = 0, w = 0.5
  w <- 0.5
  s <- rbinom(n, 1, w)
  ifelse(s == 1,
         2 + rnorm(n, sd = sd),
        -2 + rnorm(n, sd = sd))
}
###########################


# Alternatives (mean != median typically)

r_alt_spiky_multimodal <- function(n) {
  s <- sample(c(-1, 1), size = n, replace = TRUE)
  s * 2 + rnorm(n, sd = 0.25)
}

r_alt_shifted_exp <- function(n, delta = 0) {
  (rexp(n) - 1) + delta
}

# IMPORTANT: recenter by population mean (not sample mean) for stability
r_alt_pointmass_exp <- function(n, p0 = 0.30, delta = 0) {
  u <- runif(n)
  x <- ifelse(u < p0, 0, rexp(n))
  x - (1 - p0) + delta
}

##################
test_general_h_from_boot <- function(h_star, alpha = 0.05) {
  L <- as.numeric(quantile(h_star, probs = alpha/2))
  U <- as.numeric(quantile(h_star, probs = 1 - alpha/2))
  list(reject = (0 < L) || (0 > U), L = L, U = U)
}
####################
run_size_compare_fast <- function(sample_sizes = c(10,20,40),
                                  alpha = 0.05,
                                  nsim = 2000,
                                  B = 1000,
                                  K = 61,
                                  delta = function(x) 2 * sd(x) / sqrt(length(x)),
                                  use_m_out_of_n = FALSE,
                                  m_power = 0.7,
                                  seed = 1) {


  null_list <- list(
  "t(df=3)" = r_null_t3,
  "contaminated normal" = r_null_contaminated_normal,
  "Laplace" = r_null_laplace,
  "Symmetric Gaussian mixture" = r_null_asym_gaussian_mix0 # add Asymmetric Gaussian mixture with delta=0
)

  set.seed(seed)
  out <- list(); idx <- 1

  for (n in sample_sizes) {
    for (nm in names(null_list)) {
      rP <- null_list[[nm]]

      rej_pw <- logical(nsim)
      rej_h  <- logical(nsim)

      for (i in seq_len(nsim)) {
        x <- rP(n)

        # one bootstrap draw reused for both methods
        bt <- boot_th_and_h(x, B = B,
                            use_m_out_of_n = use_m_out_of_n,
                            m_power = m_power)

        # pointwise (vectorized)
        th_hat <- bt$th_hat
        Sinv <- solve(bt$Sigma_hat + diag(1e-10, 2))

        a_new <- alpha_new(alpha, 1, 2)
        q2 <- qchisq(1 - a_new, df = 2)

        delt <- if (is.function(delta)) delta(x) else delta
        tgrid <- seq(th_hat[1] - delt, th_hat[1] + delt, length.out = K)
        D <- cbind(th_hat[1] - tgrid, th_hat[2] - tgrid)
        stats <- rowSums((D %*% Sinv) * D)
        rej_pw[i] <- all(stats > q2)

        # general h test from same bootstrap
        rej_h[i] <- test_general_h_from_boot(bt$h_star, alpha = alpha)$reject
      }

      p_pw <- mean(rej_pw); p_h <- mean(rej_h)

      out[[idx]] <- data.frame(
        Study="Size", n=n, Dist=nm,
        Method = if (use_m_out_of_n) "Pointwise over t-grid (m-out-of-n)" else "Pointwise over t-grid",
        RejectRate=p_pw,
        SE=sqrt(p_pw*(1-p_pw)/nsim),
        nsim=nsim, B=B, K=K,
        m_power = if (use_m_out_of_n) m_power else NA_real_
      ); idx <- idx + 1

      out[[idx]] <- data.frame(
        Study="Size", n=n, Dist=nm,
        Method="Benchmark test of h=0",
        RejectRate=p_h,
        SE=sqrt(p_h*(1-p_h)/nsim),
        nsim=nsim, B=B, K=K,
        m_power = NA_real_
      ); idx <- idx + 1
    }
  }

  do.call(rbind, out)
}

